{
  "expo": {
    "name": "寵物共讀專注",
    "slug": "pet-study-focus-mvp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./figure/studyapp_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./figure/background.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFF8ED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.laetitia.petstudyfocus",
      "infoPlist": {
        "NSCameraUsageDescription": "需要使用相機拍攝讀書前後的打卡照片。"
      }
    },
    "android": {
      "package": "com.laetitia.petstudyfocus",
      "permissions": ["CAMERA"],
      "adaptiveIcon": {
        "foregroundImage": "./figure/studyapp_logo.png",
        "backgroundColor": "#FFF8ED"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "需要使用相機拍攝讀書前後的打卡照片。"
        }
      ]
    ],
    "extra": {
      "demoMode": true
    }
  }
}
